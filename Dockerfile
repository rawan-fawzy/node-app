# 1. تحديد النسخة الأساسية من Node.js
FROM node:18

# 2. تحديد مجلد العمل داخل الحاوية
WORKDIR /app

# 3. نسخ ملفات تعريف المكتبات أولاً (لتحسين سرعة البناء)
COPY package*.json ./

# 4. تحميل المكتبات المطلوبة للمشروع
RUN npm install

# 5. نسخ باقي كود التطبيق إلى داخل الحاوية
COPY . .

# 6. إخبار دوكر بأن التطبيق سيعمل على بورت 3000
EXPOSE 3000

# 7. الأمر النهائي لتشغيل التطبيق بمجرد تشغيل الحاوية
CMD ["node", "index.js"]